      "CompProperties_Hibernatable": "CompProperties_Hibernatable",
      "CompProperties_EquippableAbility": "CompProperties_EquippableAbility",
      "CompProperties_EquippableAbilityReloadable": "CompProperties_EquippableAbilityReloadable",
      "CompProperties_UniqueWeapon": "CompProperties_UniqueWeapon",
      "CompProperties_GravshipFacility": "CompProperties_GravshipFacility",
      "CompProperties_GravshipThruster": "CompProperties_GravshipThruster",
      "CompProperties_Transporter": "CompProperties_Transporter",
      "CompProperties_Shuttle": "CompProperties_Shuttle"
    }
  },
  "fields": {
    "Class": {
      "label": "Properties class",
      "description": "C# CompProperties type used by RimWorld DirectXmlLoader for this list item.",

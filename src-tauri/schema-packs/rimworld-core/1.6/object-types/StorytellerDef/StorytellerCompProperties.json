{
  "objectType": "StorytellerCompProperties",
  "label": "Storyteller comp properties",
  "description": "Base schema for StorytellerDef comps. Specific item schemas are selected by the li Class attribute.",
  "fieldOrder": [
    "Class",
    "compClass",
    "minDaysPassed",
    "allowedTargetTags",
    "disallowedTargetTags",
    "minIncChancePopulationIntentFactor",
    "enableIfAnyModActive",
    "disableIfAnyModActive"
  ],
  "discriminator": {
    "attribute": "Class",
    "fallbackSchemaRef": "StorytellerCompProperties",
    "allowMissing": true,
    "allowUnknown": true,
    "variants": {
      "StorytellerCompProperties_OnOffCycle": "StorytellerCompProperties_OnOffCycle",
      "StorytellerCompProperties_RandomMain": "StorytellerCompProperties_RandomMain",
      "StorytellerCompProperties_ThreatsGenerator": "StorytellerCompProperties_ThreatsGenerator",
      "StorytellerCompProperties_RandomQuest": "StorytellerCompProperties_RandomQuest",
      "StorytellerCompProperties_FactionInteraction": "StorytellerCompProperties_FactionInteraction",
      "StorytellerCompProperties_SingleMTB": "StorytellerCompProperties_SingleMTB",
      "StorytellerCompProperties_SingleOnceFixed": "StorytellerCompProperties_SingleOnceFixed",
      "StorytellerCompProperties_ClassicIntro": "StorytellerCompProperties_ClassicIntro",
      "StorytellerCompProperties_CategoryMTB": "StorytellerCompProperties_CategoryMTB",
      "StorytellerCompProperties_Disease": "StorytellerCompProperties_Disease",
      "StorytellerCompProperties_CategoryIndividualMTBByBiome": "StorytellerCompProperties_CategoryIndividualMTBByBiome",
      "StorytellerCompProperties_RefiringUniqueQuest": "StorytellerCompProperties_RefiringUniqueQuest",
      "StorytellerCompProperties_ImportantQuest": "StorytellerCompProperties_ImportantQuest",
      "StorytellerCompProperties_DeepDrillInfestation": "StorytellerCompProperties_DeepDrillInfestation",
      "StorytellerCompProperties_RandomEpicQuest": "StorytellerCompProperties_RandomEpicQuest",
      "StorytellerCompProperties_ShipChunkDrop": "StorytellerCompProperties_ShipChunkDrop",
      "StorytellerCompProperties_Triggered": "StorytellerCompProperties_Triggered",
      "StorytellerCompProperties_WorkSite": "StorytellerCompProperties_WorkSite",
      "StorytellerCompProperties_GauranlenPodSpawn": "StorytellerCompProperties_GauranlenPodSpawn",
      "StorytellerCompProperties_MonolithMigration": "StorytellerCompProperties_MonolithMigration",
      "StorytellerCompProperties_NoxiousHaze": "StorytellerCompProperties_NoxiousHaze",
      "StorytellerCompProperties_DissolutionTriggered": "StorytellerCompProperties_DissolutionTriggered"
    }
  },
  "fields": {
    "Class": {
      "label": "Properties class",
      "description": "C# StorytellerCompProperties type used by RimWorld DirectXmlLoader for this list item.",
      "type": { "kind": "typeName" },
      "required": false,
      "xml": "attribute"
    },
    "compClass": {
      "label": "Component class",
      "description": "Runtime StorytellerComp class. Usually set by the StorytellerCompProperties constructor.",
      "type": { "kind": "typeName" },
      "required": false,
      "xml": "element"
    },
    "minDaysPassed": {
      "label": "Min days passed",
      "description": "Earliest in-game day (from game start) on which this comp can fire.",
      "type": { "kind": "float" },
      "required": false,
      "defaultValue": 0,
      "xml": "element"
    },
    "allowedTargetTags": {
      "label": "Allowed target tags",
      "description": "Restrict this comp to firing at incident targets with one of these tags.",
      "type": { "kind": "list" },
      "items": { "kind": "defReference", "reference": { "defType": "IncidentTargetTagDef", "allowAbstract": false, "scope": "allSources" } },
      "required": false,
      "xml": "listOfLi"
    },
    "disallowedTargetTags": {
      "label": "Disallowed target tags",
      "description": "Exclude incident targets with any of these tags.",
      "type": { "kind": "list" },
      "items": { "kind": "defReference", "reference": { "defType": "IncidentTargetTagDef", "allowAbstract": false, "scope": "allSources" } },
      "required": false,
      "xml": "listOfLi"
    },
    "minIncChancePopulationIntentFactor": {
      "label": "Min inc chance population intent factor",
      "description": "Minimum population-intent multiplier applied to incident chance from this comp.",
      "type": { "kind": "float" },
      "required": false,
      "defaultValue": 0.05,
      "xml": "element"
    },
    "enableIfAnyModActive": {
      "label": "Enable if any mod active",
      "description": "This comp is active only when at least one mod in this list (by packageId) is loaded.",
      "type": { "kind": "list" },
      "items": { "kind": "string" },
      "required": false,
      "xml": "listOfLi"
    },
    "disableIfAnyModActive": {
      "label": "Disable if any mod active",
      "description": "This comp is disabled when any mod in this list (by packageId) is loaded.",
      "type": { "kind": "list" },
      "items": { "kind": "string" },
      "required": false,
      "xml": "listOfLi"
    }
  }
}

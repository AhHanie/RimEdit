      "type": { "kind": "list" },
      "required": false,
      "xml": "listOfLi",
      "reference": { "defType": "HediffDef", "allowAbstract": false, "scope": "allSources" }
    },
    "gender": {
      "label": "Gender",
      "description": "Gender the unwillingness applies to.",
      "type": { "kind": "enum" },
      "required": false,
      "xml": "element",
      "validationHints": { "allowedValues": ["None", "Male", "Female"] }
    },
    "displayDescription": {
      "label": "Display description",
      "description": "Whether to show the description for this comp in the UI.",
      "type": { "kind": "boolean" },
      "required": false,
      "defaultValue": true,
      "xml": "element"
    }
  }

      "required": false,
      "xml": "attribute"
    },
    "description": {
      "label": "Description",
      "description": "Description shown in the ideology editor.",
      "type": { "kind": "localizedString" },
      "required": false,
      "xml": "element"
    },
    "eventDef": {
      "label": "Event def",

{
  "name": "rimedit",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretest": "pnpm i18n:check",
    "test": "vitest run",
    "test:watch": "vitest",
    "i18n:generate": "node scripts/i18n/generate-translation-keys.mjs",
    "i18n:validate": "node scripts/i18n/validate-i18n-resources.mjs",
    "i18n:check-diagnostic-args": "node scripts/i18n/check-diagnostic-args.mjs",
    "i18n:check-hardcoded-strings": "node scripts/i18n/check-hardcoded-jsx-strings.mjs",
    "i18n:check-diagnostic-registry": "node scripts/i18n/check-diagnostic-registry.mjs",
    "i18n:check": "pnpm i18n:validate && pnpm i18n:check-diagnostic-args && pnpm i18n:check-hardcoded-strings && pnpm i18n:check-diagnostic-registry"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/highlight": "^1.2.3",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "codemirror": "^6.0.2",
    "i18next": "^26.3.6",
    "lucide-react": "^1.16.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.9",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/ui": "^4.1.7",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.7"
  }
}
